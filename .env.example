# shopify-admin-cli environment variables.
# Copy to `.env` (gitignored) and fill in values.

# @required
# @how-to-get https://shopify.dev/docs/apps/build/authentication-authorization/access-tokens/admin-api-access-tokens
# @format Long-lived custom-app admin API access token (shpat_...). Treat as a secret.
# SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# @required
# @how-to-get The admin domain of your store (Settings → Domains).
# @format <name>.myshopify.com (no protocol, no trailing slash)
# SHOPIFY_STORE_URL=your-store.myshopify.com

# @optional
# @validation-command shop info
# Override the API base URL — used by integration tests to point at a local mock server.
# Format: http://127.0.0.1:<port>  (the SDK will POST /admin/api/<version>/graphql.json there)
# SHOPIFY_ADMIN_BASE_URL=http://127.0.0.1:3000
